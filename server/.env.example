# ── Beacon server configuration ───────────────────────────────────────────
# Copy to server/.env and fill in. The server refuses to start without JWT_SECRET.

# Port the Node server listens on (Caddy proxies to this; not public).
PORT=3001

# REQUIRED. Sign JWTs with a long random secret. Generate one with:
#   openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# Comma-separated list of origins allowed to call the API / open sockets.
# In production set this to your real site origin (https, with the subdomain).
ALLOWED_ORIGINS=https://beacon.example.com

# Where the SQLite database lives. Keep it OUTSIDE the git checkout so
# `git pull` / redeploys never touch it.
DB_PATH=/opt/beacon/data/beacon.db

# ── TURN (WebRTC relay fallback) ──────────────────────────────────────────
# Needed for the minority of users behind strict NATs/firewalls. Pick ONE:
#
# Option A — a managed provider's REST API (e.g. Metered). The server fetches
# the credentialed server list and only ever exposes it (never the API key):
# TURN_CREDENTIAL_API_URL=https://yoursubdomain.metered.live/api/v1/turn/credentials?apiKey=YOUR_API_KEY
#
# Option B — a single static TURN server (e.g. self-hosted coturn, see deploy/coturn.conf):
# TURN_SERVER_URL=turn:beacon.example.com:3478
# TURN_SERVER_USERNAME=beacon
# TURN_SERVER_PASSWORD=change-me
